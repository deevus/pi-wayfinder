{
  "name": "pi-wayfinder",
  "version": "0.1.0",
  "description": "Structure-aware code navigation and anchor-stable editing tools for pi agents.",
  "type": "module",
  "keywords": [
    "pi-package",
    "wayfinder",
    "dirac",
    "coding-agent",
    "code-navigation",
    "code-editing",
    "anchor-stable-editing",
    "hash-anchored",
    "tree-sitter",
    "ast",
    "ast-tools",
    "symbol-search",
    "symbol-rename",
    "refactoring"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/deevus/pi-wayfinder.git"
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "license": "Apache-2.0"
}
